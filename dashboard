<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ApplyTrack — Dashboard</title>
    <link rel="stylesheet" href="css/styles.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <style>
      html,
      body {
        height: 100%;
        background: var(--bg-alt);
        overflow: hidden;
      }

      .shell {
        display: flex;
        height: 100vh;
      }

      .sidebar {
        width: 220px;
        flex-shrink: 0;
        background: var(--bg);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        padding: 0;
        z-index: 10;
      }

      .sb-logo {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 20px 20px 16px;
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 17px;
        color: var(--purple-600);
        border-bottom: 1px solid var(--border);
      }

      .sb-logo-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--purple-600);
      }

      .sb-nav {
        flex: 1;
        padding: 12px 10px;
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .sb-link {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 9px 12px;
        border-radius: var(--radius-md);
        font-size: 13px;
        font-weight: 500;
        color: var(--muted);
        cursor: pointer;
        transition: all var(--ease);
        border: none;
        background: none;
        font-family: var(--font-body);
        text-align: left;
        width: 100%;
      }

      .sb-link:hover {
        background: var(--bg-alt);
        color: var(--text);
      }

      .sb-link.active {
        background: var(--purple-50);
        color: var(--purple-600);
      }

      .sb-link svg {
        flex-shrink: 0;
      }

      .sb-section {
        font-size: 10px;
        font-weight: 700;
        color: var(--gray-400);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 12px 12px 4px;
      }

      .sb-footer {
        padding: 16px;
        border-top: 1px solid var(--border);
      }

      .sb-user {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .sb-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--purple-100);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: var(--purple-800);
      }

      .sb-user-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
      }

      .sb-user-sub {
        font-size: 11px;
        color: var(--muted);
      }

      .main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }

      .topbar {
        background: var(--bg);
        border-bottom: 1px solid var(--border);
        padding: 0 28px;
        height: 56px;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .topbar-title {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 700;
        color: var(--text);
      }

      .topbar-actions {
        display: flex;
        gap: 8px;
        align-items: center;
      }

      .content {
        flex: 1;
        overflow-y: auto;
        padding: 24px 28px;
      }

      .view {
        display: none;
      }

      .view.active {
        display: block;
      }

      .metrics-row {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 12px;
        margin-bottom: 20px;
      }

      .metric-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 16px 18px;
      }

      .metric-card-num {
        font-family: var(--font-display);
        font-size: 26px;
        font-weight: 700;
        color: var(--purple-600);
      }

      .metric-card-label {
        font-size: 11px;
        color: var(--muted);
        margin-top: 2px;
      }

      .metric-card-sub {
        font-size: 11px;
        color: var(--muted);
        margin-top: 6px;
      }

      .deadline-strip {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 12px 18px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .deadline-strip-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text);
        flex-shrink: 0;
      }

      .deadline-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 11px;
        padding: 3px 10px;
        border-radius: var(--radius-pill);
        font-weight: 600;
        cursor: pointer;
      }

      .deadline-pill.overdue {
        background: var(--color-rejected-bg);
        color: var(--color-rejected-text);
      }

      .deadline-pill.soon {
        background: var(--color-interview-bg);
        color: var(--color-interview-text);
      }

      .deadline-pill.ok {
        background: var(--color-offer-bg);
        color: var(--color-offer-text);
      }

      .deadline-empty {
        font-size: 12px;
        color: var(--muted);
      }

      .table-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
      }

      .table-card-head {
        padding: 12px 18px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .table-search {
        flex: 1;
        min-width: 160px;
        max-width: 260px;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 7px 12px 7px 34px;
        font-size: 13px;
        font-family: var(--font-body);
        background: var(--bg-alt);
        color: var(--text);
        outline: none;
        transition: border-color var(--ease);
      }

      .table-search:focus {
        border-color: var(--purple-400);
      }

      .search-wrap {
        position: relative;
        flex: 1;
        max-width: 260px;
      }

      .search-icon {
        position: absolute;
        left: 10px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--muted);
        pointer-events: none;
      }

      .filter-select {
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 7px 10px;
        font-size: 12px;
        font-family: var(--font-body);
        color: var(--text);
        background: var(--bg-alt);
        outline: none;
        cursor: pointer;
      }

      .tbl {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }

      .tbl th {
        padding: 10px 16px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        color: var(--muted);
        border-bottom: 1px solid var(--border);
        background: var(--bg-alt);
        white-space: nowrap;
      }

      .tbl td {
        padding: 11px 16px;
        border-bottom: 1px solid var(--border);
        color: var(--text);
        vertical-align: middle;
      }

      .tbl tr:last-child td {
        border-bottom: none;
      }

      .tbl tr.app-row {
        transition: background var(--ease);
        cursor: pointer;
      }

      .tbl tr.app-row:hover td {
        background: var(--bg-alt);
      }

      .co-initial {
        width: 28px;
        height: 28px;
        border-radius: 7px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        margin-right: 8px;
        vertical-align: middle;
        flex-shrink: 0;
      }

      .co-name {
        font-weight: 600;
      }

      .tbl-empty {
        padding: 48px;
        text-align: center;
        color: var(--muted);
        font-size: 14px;
      }

      .s-badge {
        display: inline-block;
        font-size: 10px;
        font-weight: 700;
        padding: 3px 9px;
        border-radius: var(--radius-pill);
        white-space: nowrap;
      }

      .s-wishlist {
        background: #f3e8ff;
        color: #6b21a8;
      }

      .s-applied {
        background: var(--color-applied-bg);
        color: var(--color-applied-text);
      }

      .s-oa {
        background: #fef3c7;
        color: #92400e;
      }

      .s-phone {
        background: #dbeafe;
        color: #1e40af;
      }

      .s-interview {
        background: var(--color-interview-bg);
        color: var(--color-interview-text);
      }

      .s-offer {
        background: var(--color-offer-bg);
        color: var(--color-offer-text);
      }

      .s-rejected {
        background: var(--color-rejected-bg);
        color: var(--color-rejected-text);
      }

      .s-withdrawn {
        background: var(--gray-100);
        color: var(--gray-500);
      }

      .row-actions {
        display: flex;
        gap: 4px;
        opacity: 0;
        transition: opacity var(--ease);
      }

      .tbl tr.app-row:hover .row-actions {
        opacity: 1;
      }

      .row-btn {
        border: none;
        background: none;
        cursor: pointer;
        padding: 4px 6px;
        border-radius: var(--radius-sm);
        color: var(--muted);
        transition: all var(--ease);
      }

      .row-btn:hover {
        background: var(--bg-alt);
        color: var(--text);
      }

      .row-btn.del:hover {
        color: var(--color-error);
      }

      .modal-backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.35);
        z-index: 200;
        display: none;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(2px);
      }

      .modal-backdrop.open {
        display: flex;
      }

      .modal {
        background: var(--bg);
        border-radius: var(--radius-xl);
        width: 100%;
        max-width: 600px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: var(--shadow-lg);
        animation: modalIn 0.2s ease;
      }

      @keyframes modalIn {
        from {
          opacity: 0;
          transform: translateY(16px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .modal-head {
        padding: 20px 24px 16px;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: sticky;
        top: 0;
        background: var(--bg);
        z-index: 1;
      }

      .modal-title {
        font-family: var(--font-display);
        font-size: 17px;
        font-weight: 700;
        color: var(--text);
      }

      .modal-close {
        border: none;
        background: none;
        cursor: pointer;
        color: var(--muted);
        padding: 4px;
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        transition: color var(--ease);
      }

      .modal-close:hover {
        color: var(--text);
      }

      .modal-body {
        padding: 20px 24px;
      }

      .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: flex-end;
        gap: 8px;
      }

      .modal-tabs {
        display: flex;
        gap: 2px;
        border-bottom: 1px solid var(--border);
        margin: -20px -24px 20px;
        padding: 0 24px;
      }

      .modal-tab {
        padding: 10px 14px;
        font-size: 13px;
        font-weight: 600;
        color: var(--muted);
        cursor: pointer;
        border: none;
        background: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        transition: all var(--ease);
        font-family: var(--font-body);
      }

      .modal-tab.active {
        color: var(--purple-600);
        border-bottom-color: var(--purple-600);
      }

      .modal-tab-panel {
        display: none;
      }

      .modal-tab-panel.active {
        display: block;
      }

      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
      }

      .form-grid.single {
        grid-template-columns: 1fr;
      }

      .f-group {
        display: flex;
        flex-direction: column;
        gap: 5px;
      }

      .f-group.span2 {
        grid-column: 1 / -1;
      }

      .f-label {
        font-size: 12px;
        font-weight: 600;
        color: var(--gray-700);
      }

      .f-input,
      .f-select,
      .f-textarea {
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 9px 12px;
        font-size: 13px;
        font-family: var(--font-body);
        color: var(--text);
        background: var(--bg);
        outline: none;
        transition: border-color var(--ease), box-shadow var(--ease);
        width: 100%;
      }

      .f-input:focus,
      .f-select:focus,
      .f-textarea:focus {
        border-color: var(--purple-400);
        box-shadow: 0 0 0 3px rgba(83, 74, 183, 0.09);
      }

      .f-textarea {
        resize: vertical;
        min-height: 90px;
      }

      .f-section {
        font-size: 11px;
        font-weight: 700;
        color: var(--purple-600);
        letter-spacing: 0.07em;
        text-transform: uppercase;
        margin: 16px 0 10px;
        border-top: 1px solid var(--border);
        padding-top: 14px;
      }

      .note-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 12px;
      }

      .note-item {
        background: var(--bg-alt);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 10px 12px;
      }

      .note-item-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3px;
      }

      .note-item-date {
        font-size: 11px;
        color: var(--muted);
      }

      .note-item-text {
        font-size: 13px;
        color: var(--text);
      }

      .note-del {
        border: none;
        background: none;
        cursor: pointer;
        color: var(--muted);
        font-size: 14px;
        line-height: 1;
      }

      .note-del:hover {
        color: var(--color-error);
      }

      .note-add-row {
        display: flex;
        gap: 8px;
      }

      .note-add-row .f-input {
        flex: 1;
      }

      .doc-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 12px;
      }

      .doc-item {
        background: var(--bg-alt);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 10px 12px;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .doc-icon {
        color: var(--purple-400);
        flex-shrink: 0;
      }

      .doc-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        flex: 1;
      }

      .doc-type {
        font-size: 11px;
        color: var(--muted);
      }

      .doc-link {
        font-size: 12px;
        color: var(--purple-600);
        word-break: break-all;
      }

      .doc-del {
        border: none;
        background: none;
        cursor: pointer;
        color: var(--muted);
        margin-left: auto;
      }

      .doc-del:hover {
        color: var(--color-error);
      }

      .analytics-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        margin-top: 20px;
      }

      .chart-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px;
      }

      .chart-card.full {
        grid-column: 1 / -1;
      }

      .chart-title {
        font-family: var(--font-display);
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
      }

      .chart-sub {
        font-size: 12px;
        color: var(--muted);
        margin-bottom: 16px;
      }

      .chart-wrap {
        position: relative;
      }

      .funnel {
        display: flex;
        flex-direction: column;
        gap: 6px;
      }

      .funnel-row {
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .funnel-label {
        font-size: 12px;
        color: var(--text);
        width: 90px;
        flex-shrink: 0;
        font-weight: 500;
      }

      .funnel-bar-wrap {
        flex: 1;
        background: var(--bg-alt);
        border-radius: var(--radius-pill);
        height: 20px;
        overflow: hidden;
      }

      .funnel-bar {
        height: 100%;
        border-radius: var(--radius-pill);
        background: var(--purple-400);
        transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
        display: flex;
        align-items: center;
        padding: 0 8px;
      }

      .funnel-count {
        font-size: 11px;
        font-weight: 700;
        color: #fff;
        white-space: nowrap;
      }

      .funnel-pct {
        font-size: 11px;
        color: var(--muted);
        width: 36px;
        text-align: right;
        flex-shrink: 0;
      }

      .dist-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .dist-row {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .dist-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .dist-name {
        font-size: 12px;
        color: var(--text);
        flex: 1;
      }

      .dist-count {
        font-size: 12px;
        font-weight: 700;
        color: var(--text);
      }

      .dist-pct {
        font-size: 11px;
        color: var(--muted);
        width: 32px;
        text-align: right;
      }

      .reminder-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .reminder-card {
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .reminder-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
      }

      .reminder-company {
        font-size: 14px;
        font-weight: 700;
        color: var(--text);
      }

      .reminder-desc {
        font-size: 12px;
        color: var(--muted);
      }

      .reminder-date {
        font-size: 12px;
        font-weight: 600;
        margin-left: auto;
        white-space: nowrap;
      }

      .reminder-empty {
        text-align: center;
        padding: 48px;
        color: var(--muted);
        font-size: 14px;
      }

      .btn-sm {
        padding: 7px 14px;
        border-radius: var(--radius-md);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        font-family: var(--font-display);
        border: none;
        transition: all var(--ease);
      }

      .btn-sm.primary {
        background: var(--purple-600);
        color: #fff;
      }

      .btn-sm.primary:hover {
        background: var(--purple-800);
      }

      .btn-sm.ghost {
        background: transparent;
        color: var(--muted);
        border: 1px solid var(--border);
      }

      .btn-sm.ghost:hover {
        background: var(--bg-alt);
        color: var(--text);
      }

      .btn-sm.danger {
        background: var(--color-rejected-bg);
        color: var(--color-error);
        border: 1px solid #f0c0c0;
      }

      .btn-sm.danger:hover {
        background: #fce4e4;
      }

      .toast {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 999;
        background: var(--bg);
        border: 1px solid var(--purple-200);
        border-radius: var(--radius-lg);
        padding: 12px 18px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        box-shadow: var(--shadow-lg);
        color: var(--text);
        transform: translateY(60px);
        opacity: 0;
        transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      }

      .toast.show {
        transform: translateY(0);
        opacity: 1;
      }

      .toast-icon {
        color: var(--color-offer-text);
      }

      @media (max-width: 900px) {
        .sidebar {
          display: none;
        }

        .metrics-row {
          grid-template-columns: repeat(3, 1fr);
        }

        .analytics-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 600px) {
        .metrics-row {
          grid-template-columns: 1fr 1fr;
        }

        .form-grid {
          grid-template-columns: 1fr;
        }

        .form-grid .f-group.span2 {
          grid-column: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <div class="sb-logo"><span class="sb-logo-dot"></span> ApplyTrack</div>

        <nav class="sb-nav">
          <div class="sb-section">Main</div>

          <button class="sb-link active" onclick="showView('applications',this)">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <path d="M8 21h8M12 17v4" />
            </svg>
            Applications
          </button>

          <button class="sb-link" onclick="showView('reminders',this)">
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
