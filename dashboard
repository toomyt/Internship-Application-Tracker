        const exportBtn = document.getElementById('export-btn');

        addBtn.style.display = name === 'applications' ? '' : 'none';
        exportBtn.style.display = name === 'applications' ? '' : 'none';

        if (name === 'analytics') renderAnalytics();
        if (name === 'reminders') renderReminders();
      }


      function updateMetrics() {
        const apps = load();
        const total = apps.length;
        const active = apps.filter((a) => ACTIVE_STATUSES.includes(a.status)).length;
        const interview = apps.filter((a) => a.status === 'Interview').length;
        const offer = apps.filter((a) => a.status === 'Offer').length;
        const responded = apps.filter((a) => !['Wishlist', 'Applied'].includes(a.status)).length;
        const applied = apps.filter((a) => a.status !== 'Wishlist').length;
        const rate = applied ? Math.round((responded / applied) * 100) : 0;

        document.getElementById('m-total').textContent = total;
        document.getElementById('m-active').textContent = active;
        document.getElementById('m-interview').textContent = interview;
        document.getElementById('m-offer').textContent = offer;
        document.getElementById('m-response').textContent = rate + '%';
      }

      function updateDeadlineStrip() {
        const apps = load();
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const items = [];

        apps.forEach((app) => {
          const dls = {
            apply: 'Apply',
            followup: 'Follow-up',
            interview: 'Interview',
            offer: 'Offer decision',
          };

          Object.entries(dls).forEach(([k, label]) => {
            if (!app.deadlines[k]) return;
            const dt = new Date(app.deadlines[k]);
            dt.setHours(0, 0, 0, 0);
            const diff = Math.round((dt - today) / 86400000);
            items.push({ app, label, dt, diff });
          });
        });

        items.sort((a, b) => a.dt - b.dt);
        const container = document.getElementById('deadline-pills');

        if (!items.length) {
          container.innerHTML = '<span class="deadline-empty">No deadlines set</span>';
          return;
        }

        const upcoming = items.slice(0, 6);
        container.innerHTML = upcoming
          .map(({ app, label, diff }) => {
            const cls = diff < 0 ? 'overdue' : diff <= 3 ? 'soon' : 'ok';
            const txt = diff < 0 ? `${Math.abs(diff)}d overdue` : diff === 0 ? 'Today' : `${diff}d`;
            return `<span class="deadline-pill ${cls}" onclick="openEdit('${app.id}')">${app.company} · ${label}: ${txt}</span>`;
          })
          .join('');
      }

      function renderTable() {
        const apps = load();
        const search = document.getElementById('search-input').value.toLowerCase();
        const status = document.getElementById('status-filter').value;
        const sort = document.getElementById('sort-select').value;

        let filtered = apps.filter((a) => {
          const matchS = !status || a.status === status;
          const matchQ =
            !search ||
            a.company.toLowerCase().includes(search) ||
            a.role.toLowerCase().includes(search);
          return matchS && matchQ;
        });

        if (sort === 'date-desc') {
          filtered.sort((a, b) => (b.dateApplied || '').localeCompare(a.dateApplied || ''));
        } else if (sort === 'date-asc') {
          filtered.sort((a, b) => (a.dateApplied || '').localeCompare(b.dateApplied || ''));
        } else if (sort === 'company') {
          filtered.sort((a, b) => a.company.localeCompare(b.company));
        } else if (sort === 'deadline') {
          filtered.sort((a, b) => {
            const da = Object.values(a.deadlines).filter(Boolean).sort()[0] || '9999';
            const db = Object.values(b.deadlines).filter(Boolean).sort()[0] || '9999';
            return da.localeCompare(db);
          });
        }

        const tbody = document.getElementById('app-tbody');

        if (!filtered.length) {
          tbody.innerHTML =
            '<tr><td colspan="7" class="tbl-empty">No applications found. Add one to get started!</td></tr>';
          return;
        }

        tbody.innerHTML = filtered
          .map((app) => {
            const clr = stringToColor(app.company);
            const initials = app.company.slice(0, 1).toUpperCase();
            const dateStr = app.dateApplied
              ? new Date(app.dateApplied + 'T00:00:00').toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                  year: 'numeric',
                })
              : '—';
            const earliest = Object.values(app.deadlines).filter(Boolean).sort()[0];
            const dlStr = earliest ? formatDeadline(earliest) : '—';
            const badgeCls = STATUS_CLASS[app.status] || 's-applied';
            const noteCount = (app.interactionNotes || []).length;
            const docCount = (app.docs || []).length;

            return `<tr class="app-row" onclick="openEdit('${app.id}')">
            <td><span class="co-initial" style="background:${clr}20;color:${clr}">${initials}</span><span class="co-name">${esc(app.company)}</span></td>
            <td>${esc(app.role)}</td>
            <td><span class="s-badge ${badgeCls}">${esc(app.status)}</span></td>
            <td style="color:var(--muted)">${dateStr}</td>
            <td style="color:var(--muted)">${dlStr}</td>
            <td style="color:var(--muted)">${esc(app.source || '—')}</td>
            <td>
              <div class="row-actions" onclick="event.stopPropagation()">
                ${noteCount ? `<span style="font-size:11px;color:var(--muted)">${noteCount} note${noteCount > 1 ? 's' : ''}</span>` : ''}
                ${docCount ? `<span style="font-size:11px;color:var(--muted)">${docCount} doc${docCount > 1 ? 's' : ''}</span>` : ''}
                <button class="row-btn" title="Edit" onclick="openEdit('${app.id}')">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                </button>
                <button class="row-btn del" title="Delete" onclick="event.stopPropagation();quickDelete('${app.id}')">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
              </div>
            </td>
          </tr>`;
          })
          .join('');
      }

      function formatDeadline(dateStr) {
        const dt = new Date(dateStr + 'T00:00:00');
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const diff = Math.round((dt - today) / 86400000);

        if (diff < 0) return `<span style="color:var(--color-error)">${Math.abs(diff)}d ago</span>`;
        if (diff === 0) return `<span style="color:#854F0B">Today</span>`;
        if (diff <= 3) return `<span style="color:#854F0B">in ${diff}d</span>`;

        return dt.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      }

      let editingId = null;
      let tempNotes = [];
      let tempDocs = [];

      function openAdd() {
        editingId = null;
        document.getElementById('modal-title').textContent = 'Add Application';
        document.getElementById('delete-btn').style.display = 'none';
        clearForm();
        tempNotes = [];
        tempDocs = [];
        switchModalTab('details', document.querySelector('.modal-tab'));
        renderNotesUI();
        renderDocsUI();
        document.getElementById('f-date').value = new Date().toISOString().slice(0, 10);
        document.getElementById('app-modal').classList.add('open');
      }

      function openEdit(id) {
        const apps = load();
        const app = apps.find((a) => a.id === id);
        if (!app) return;

        editingId = id;
        document.getElementById('modal-title').textContent = 'Edit — ' + app.company;
        document.getElementById('delete-btn').style.display = '';
        fillForm(app);
        tempNotes = [...(app.interactionNotes || [])];
        tempDocs = [...(app.docs || [])];
        switchModalTab('details', document.querySelector('.modal-tab'));
        renderNotesUI();
        renderDocsUI();
        document.getElementById('app-modal').classList.add('open');
      }

      function closeModal() {
        document.getElementById('app-modal').classList.remove('open');
        editingId = null;
      }

      function clearForm() {
        [
          'f-company',
          'f-role',
          'f-date',
          'f-url',
          'f-notes',
          'f-contact-name',
          'f-contact-title',
          'f-contact-email',
          'f-contact-linkedin',
          'f-dl-apply',
          'f-dl-followup',
          'f-dl-interview',
          'f-dl-offer',
        ].forEach((id) => {
          const el = document.getElementById(id);
          if (el) el.value = '';
        });

        document.getElementById('f-status').value = 'Applied';
        document.getElementById('f-source').value = '';
      }

      function fillForm(app) {
        document.getElementById('f-company').value = app.company || '';
        document.getElementById('f-role').value = app.role || '';
        document.getElementById('f-status').value = app.status || 'Applied';
        document.getElementById('f-date').value = app.dateApplied || '';
        document.getElementById('f-source').value = app.source || '';
        document.getElementById('f-url').value = app.url || '';
        document.getElementById('f-notes').value = app.notes || '';

        const c = app.contact || {};
        document.getElementById('f-contact-name').value = c.name || '';
        document.getElementById('f-contact-title').value = c.title || '';
        document.getElementById('f-contact-email').value = c.email || '';
        document.getElementById('f-contact-linkedin').value = c.linkedin || '';

        const dl = app.deadlines || {};
        document.getElementById('f-dl-apply').value = dl.apply || '';
        document.getElementById('f-dl-followup').value = dl.followup || '';
        document.getElementById('f-dl-interview').value = dl.interview || '';
        document.getElementById('f-dl-offer').value = dl.offer || '';
      }

      function saveApp() {
        const company = document.getElementById('f-company').value.trim();
        const role = document.getElementById('f-role').value.trim();

        if (!company) {
          toast('Company name is required', 'warn');
          return;
        }

        if (!role) {
          toast('Role title is required', 'warn');
          return;
        }

        const app = {
          id: editingId || uid(),
          company,
          role,
          status: document.getElementById('f-status').value,
          dateApplied: document.getElementById('f-date').value,
          source: document.getElementById('f-source').value,
          url: document.getElementById('f-url').value.trim(),
          notes: document.getElementById('f-notes').value.trim(),
          contact: {
            name: document.getElementById('f-contact-name').value.trim(),
            title: document.getElementById('f-contact-title').value.trim(),
            email: document.getElementById('f-contact-email').value.trim(),
            linkedin: document.getElementById('f-contact-linkedin').value.trim(),
          },
          interactionNotes: tempNotes,
          docs: tempDocs,
          deadlines: {
            apply: document.getElementById('f-dl-apply').value,
            followup: document.getElementById('f-dl-followup').value,
            interview: document.getElementById('f-dl-interview').value,
            offer: document.getElementById('f-dl-offer').value,
          },
        };

        const apps = load();

        if (editingId) {
          const idx = apps.findIndex((a) => a.id === editingId);
          if (idx !== -1) apps[idx] = app;
        } else {
          apps.unshift(app);
        }

        save(apps);
        closeModal();
        refresh();
        toast(editingId ? 'Application updated!' : 'Application added!');
      }

      function deleteApp() {
        if (!editingId) return;
        if (!confirm('Delete this application? This cannot be undone.')) return;

        const apps = load().filter((a) => a.id !== editingId);
        save(apps);
        closeModal();
        refresh();
        toast('Application deleted');
      }

      function quickDelete(id) {
        if (!confirm('Delete this application?')) return;
        save(load().filter((a) => a.id !== id));
        refresh();
        toast('Deleted');
      }


      function addNote() {
        const txt = document.getElementById('new-note-text').value.trim();
        if (!txt) return;

        tempNotes.unshift({
          id: uid(),
          date: new Date().toISOString().slice(0, 10),
          text: txt,
        });

        document.getElementById('new-note-text').value = '';
        renderNotesUI();
      }

      function removeNote(id) {
        tempNotes = tempNotes.filter((n) => n.id !== id);
        renderNotesUI();
      }

      function renderNotesUI() {
        const container = document.getElementById('note-list');

        if (!tempNotes.length) {
          container.innerHTML =
            '<div style="font-size:13px;color:var(--muted);margin-bottom:8px">No notes yet.</div>';
          return;
        }

        container.innerHTML = tempNotes
          .map(
            (n) => `
          <div class="note-item">
            <div class="note-item-header">
              <span class="note-item-date">${n.date}</span>
              <button class="note-del" onclick="removeNote('${n.id}')">✕</button>
            </div>
            <div class="note-item-text">${esc(n.text)}</div>
          </div>`
          )
          .join('');
      }


      function addDoc() {
        const name = document.getElementById('new-doc-name').value.trim();
        const type = document.getElementById('new-doc-type').value;
        const url = document.getElementById('new-doc-url').value.trim();

        if (!name) {
          toast('Please enter a document name', 'warn');
          return;
        }

        tempDocs.push({ id: uid(), name, type, url });
        document.getElementById('new-doc-name').value = '';
        document.getElementById('new-doc-url').value = '';
        renderDocsUI();
      }

      function removeDoc(id) {
        tempDocs = tempDocs.filter((d) => d.id !== id);
        renderDocsUI();
      }

      function renderDocsUI() {
        const container = document.getElementById('doc-list');

        if (!tempDocs.length) {
          container.innerHTML =
            '<div style="font-size:13px;color:var(--muted);margin-bottom:8px">No documents attached.</div>';
          return;
        }

        container.innerHTML = tempDocs
          .map(
            (d) => `
          <div class="doc-item">
            <svg class="doc-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <div>
              <div class="doc-name">${esc(d.name)}</div>
              <div class="doc-type">${esc(d.type)}</div>
              ${d.url ? `<a class="doc-link" href="${esc(d.url)}" target="_blank" onclick="event.stopPropagation()">${esc(d.url.slice(0, 40))}${d.url.length > 40 ? '…' : ''}</a>` : ''}
            </div>
            <button class="doc-del" onclick="removeDoc('${d.id}')">✕</button>
          </div>`
          )
          .join('');
      }

      function switchModalTab(name, btn) {
        document.querySelectorAll('.modal-tab-panel').forEach((p) => p.classList.remove('active'));
        document.querySelectorAll('.modal-tab').forEach((b) => b.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        if (btn) btn.classList.add('active');
      }

      function renderReminders() {
        const apps = load();
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        const items = [];
        const dlLabels = {
          apply: 'Application due',
          followup: 'Follow-up',
          interview: 'Interview',
          offer: 'Offer decision',
        };

        apps.forEach((app) => {
          Object.entries(dlLabels).forEach(([k, label]) => {
            if (!app.deadlines[k]) return;
            const dt = new Date(app.deadlines[k] + 'T00:00:00');
            dt.setHours(0, 0, 0, 0);
            const diff = Math.round((dt - today) / 86400000);
            items.push({ app, label, dt, diff });
          });
        });

        items.sort((a, b) => a.dt - b.dt);

        const overdue = items.filter((i) => i.diff < 0);
        const upcoming = items.filter((i) => i.diff >= 0 && i.diff <= 7);
        const later = items.filter((i) => i.diff > 7);

        const container = document.getElementById('reminder-content');

        if (!items.length) {
          container.innerHTML =
            '<div class="reminder-empty">No deadlines set. Open an application and add deadlines in the Deadlines tab.</div>';
          return;
        }

        const section = (title, list, dot) =>
          list.length
            ? `
          <div style="margin-bottom:20px">
            <div style="font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.07em;text-transform:uppercase;margin-bottom:10px">${title}</div>
            <div class="reminder-list">
              ${list
                .map(
                  (i) => `
                <div class="reminder-card" onclick="openEdit('${i.app.id}')">
                  <div class="reminder-dot" style="background:${dot}"></div>
                  <div>
                    <div class="reminder-company">${esc(i.app.company)}</div>
                    <div class="reminder-desc">${esc(i.app.role)} · ${i.label}</div>
                  </div>
                  <div class="reminder-date" style="color:${dot}">
                    ${i.diff < 0 ? Math.abs(i.diff) + 'd overdue' : i.diff === 0 ? 'Today' : 'in ' + i.diff + 'd'}
                  </div>
                </div>`
                )
                .join('')}
            </div>
          </div>`
            : '';

        container.innerHTML =
          section('Overdue', overdue, '#A32D2D') +
          section('This week', upcoming, '#854F0B') +
          section('Coming up', later, '#3B6D11');
      }

      let timelineChart = null;
      let distChart = null;

      function renderAnalytics() {
        const apps = load();
        const total = apps.length;
        const applied = apps.filter((a) => a.status !== 'Wishlist').length;
        const responded = apps.filter((a) => !['Wishlist', 'Applied'].includes(a.status)).length;
        const interviewed = apps.filter((a) => ['Interview', 'Offer'].includes(a.status)).length;
        const offered = apps.filter((a) => a.status === 'Offer').length;

        document.getElementById('a-total').textContent = total;
        document.getElementById('a-response').textContent = applied
          ? Math.round((responded / applied) * 100) + '%'
          : '0%';
        document.getElementById('a-interview-rate').textContent = applied
          ? Math.round((interviewed / applied) * 100) + '%'
          : '0%';
        document.getElementById('a-offer-rate').textContent = applied
          ? Math.round((offered / applied) * 100) + '%'
          : '0%';

        renderTimeline(apps);
        renderFunnel(apps);
        renderDistribution(apps);
      }

      function renderTimeline(apps) {
        const dated = apps
          .filter((a) => a.dateApplied)
          .sort((a, b) => a.dateApplied.localeCompare(b.dateApplied));

        if (!dated.length) return;

        const weeks = {};
        dated.forEach((a) => {
          const dt = new Date(a.dateApplied + 'T00:00:00');
          const mon = new Date(dt);
          mon.setDate(dt.getDate() - dt.getDay());
          const key = mon.toISOString().slice(0, 10);
          weeks[key] = (weeks[key] || 0) + 1;
        });

        const labels = Object.keys(weeks).sort();
        const data = labels.map((k) => weeks[k]);
        const labelsFmt = labels.map((k) => {
          const d = new Date(k + 'T00:00:00');
          return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        });

        if (timelineChart) timelineChart.destroy();

        timelineChart = new Chart(document.getElementById('timeline-chart'), {
          type: 'bar',
          data: {
            labels: labelsFmt,
            datasets: [
              {
                data,
                backgroundColor: 'rgba(83,74,183,0.15)',
                borderColor: '#534AB7',
                borderWidth: 2,
                borderRadius: 6,
                hoverBackgroundColor: 'rgba(83,74,183,0.3)',
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: {
                grid: { display: false },
                ticks: { font: { size: 11 }, color: '#6b7280' },
              },
              y: {
                grid: { color: 'rgba(0,0,0,0.05)' },
                ticks: { font: { size: 11 }, color: '#6b7280', stepSize: 1 },
              },
            },
          },
        });
      }

      function renderFunnel(apps) {
        const counts = {};
        FUNNEL_STAGES.forEach((s) => (counts[s] = 0));
        apps.forEach((a) => {
          if (counts[a.status] !== undefined) counts[a.status]++;
        });

        const stageOrder = [
          'Applied',
          'Online Assessment',
          'Phone Screen',
          'Interview',
          'Offer',
        ];

        const stageIndex = (s) => stageOrder.indexOf(s);
        const cumulative = {};

        stageOrder.forEach((stage, i) => {
          cumulative[stage] = apps.filter(
            (a) => stageIndex(a.status) >= i && a.status !== 'Wishlist'
          ).length;
        });

        const max = cumulative.Applied || 1;

        document.getElementById('funnel-bars').innerHTML = stageOrder
          .map((stage, i) => {
            const count = cumulative[stage];
            const pct = Math.round((count / max) * 100);
            const convPct =
              i > 0
                ? cumulative[stageOrder[i - 1]]
                  ? Math.round((count / cumulative[stageOrder[i - 1]]) * 100)
                  : 0
                : 100;
            const colors = ['#534AB7', '#7F77DD', '#185FA5', '#854F0B', '#3B6D11'];

            return `<div class="funnel-row">
            <span class="funnel-label">${stage}</span>
            <div class="funnel-bar-wrap">
              <div class="funnel-bar" style="width:${pct}%;background:${colors[i]}">
                ${count > 0 ? `<span class="funnel-count">${count}</span>` : ''}
              </div>
            </div>
            <span class="funnel-pct">${i === 0 ? '' : convPct + '%'}</span>
          </div>`;
          })
          .join('');
      }

      function renderDistribution(apps) {
        const counts = {};
        apps.forEach((a) => {
          counts[a.status] = (counts[a.status] || 0) + 1;
        });

        const statuses = Object.entries(counts).sort((a, b) => b[1] - a[1]);
        const total = apps.length || 1;
        const colors = statuses.map(([s]) => STATUS_COLOR[s] || '#888');

        if (distChart) distChart.destroy();

        distChart = new Chart(document.getElementById('dist-chart'), {
          type: 'doughnut',
          data: {
            labels: statuses.map(([s]) => s),
            datasets: [
              {
                data: statuses.map(([, c]) => c),
                backgroundColor: colors.map((c) => c + '33'),
                borderColor: colors,
                borderWidth: 2,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '65%',
            plugins: { legend: { display: false } },
          },
        });

        document.getElementById('dist-list').innerHTML = statuses
          .map(
            ([s, c]) => `
          <div class="dist-row">
            <div class="dist-dot" style="background:${STATUS_COLOR[s] || '#888'}"></div>
            <span class="dist-name">${s}</span>
            <span class="dist-count">${c}</span>
            <span class="dist-pct">${Math.round((c / total) * 100)}%</span>
          </div>`
          )
          .join('');
      }

      function exportCSV() {
        const apps = load();
        const headers = [
          'Company',
          'Role',
          'Status',
          'Date Applied',
          'Source',
          'URL',
          'Notes',
          'Contact Name',
          'Contact Email',
          'Deadline (Apply)',
          'Deadline (Followup)',
          'Deadline (Interview)',
          'Deadline (Offer)',
        ];

        const rows = apps.map((a) =>
          [
            a.company,
            a.role,
            a.status,
            a.dateApplied,
            a.source,
            a.url,
            a.notes,
            a.contact?.name,
            a.contact?.email,
            a.deadlines?.apply,
            a.deadlines?.followup,
            a.deadlines?.interview,
            a.deadlines?.offer,
          ].map((v) => `"${(v || '').replace(/"/g, '""')}"`)
        );

        const csv = [headers.join(','), ...rows.map((r) => r.join(','))].join('\n');
        const a = document.createElement('a');
        a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
        a.download = 'applytrack_export.csv';
        a.click();
        toast('CSV exported!');
      }

      function refresh() {
        updateMetrics();
        updateDeadlineStrip();
        renderTable();
      }

      function toast(msg, type) {
        const el = document.getElementById('toast');
        const ico = document.getElementById('toast-icon') || el.querySelector('.toast-icon');
        document.getElementById('toast-msg').textContent = msg;
        el.querySelector('.toast-icon').textContent = type === 'warn' ? '⚠' : '✓';
        el.classList.add('show');
        setTimeout(() => el.classList.remove('show'), 3000);
      }

      function esc(str) {
        return (str || '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;');
      }

      function stringToColor(str) {
        let hash = 0;
        for (let i = 0; i < str.length; i++) {
          hash = str.charCodeAt(i) + ((hash << 5) - hash);
        }

        const palette = [
          '#534AB7',
          '#185FA5',
          '#854F0B',
          '#3B6D11',
          '#A32D2D',
          '#0F6E56',
          '#6B21A8',
          '#1E40AF',
        ];

        return palette[Math.abs(hash) % palette.length];
      }

      document.getElementById('app-modal').addEventListener('click', (e) => {
        if (e.target === e.currentTarget) closeModal();
      });

      seedIfEmpty();
      refresh();
    </script>
  </body>
